#. Insert the navigation mode on the index of the object mode to make it the new default
#. Translators: A label for a touch mode
#. Translators: the message reported when navigation mode is turned on.
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:59
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1644
msgid "Navigation mode"
msgstr "Режим навигации"

#. Translators: The label for a script category
#. Add-on summary, usually the user visible name of the addon.
#. Translators: Summary for this add-on
#. to be shown on installation and add-on information found in Add-ons Manager.
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:62 buildVars.py:23
msgid "Enhanced Object Navigation"
msgstr "Улучшенная объектная навигация"

#. Translators: A choice in a combo box
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:83
msgid "the window that the navigator object is in"
msgstr "окно, в котором находится объект навигатора"

#. Translators: A choice in a combo box
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:85
msgid "all objects"
msgstr "все объекты"

#. Translators: A choice in a combo box
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:87
msgid "the current browse mode document, if available"
msgstr "Текущий документ в режиме обзора, если он доступен"

#. Translators: the title of a settings panel
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:91
msgid "Enhanced object navigation"
msgstr "Улучшенная объектная навигация"

#. Translators: the label of a check box
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:100
msgid "&Use navigation mode by default"
msgstr "&Использовать режим навигации по умолчанию"

#. Translators: The label of a check box
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:104
msgid "&When searching, sort the items in tab order instead of alphabetically"
msgstr ""
"При поиске &сортировать элементы в порядке табулирования, а не алфавитно"

#. Translators: The label for a combo box
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:108
msgid "&Search scope"
msgstr "&Область поиска"

#. Translators: the label for a check box
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:112
msgid "Use &enhanced detection while searching for same item"
msgstr "Использовать &улучшенное обнаружение при поиске такого же элемента"

#. Translators: a label for a check box
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:116
msgid "Use UI automation in navigation mode when available."
msgstr "Использовать UI automation в режиме навигации, когда это возможно."

#. Translators: a label for a check box
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:121
msgid ""
"Disable asynchronous navigation, useful if you encounter problems while "
"navigating, such as NVDA becoming silent or playing error sounds"
msgstr ""
"Отключить асинхронную навигацию, это полезно, если вы сталкиваетесь с "
"проблемами во время навигации, такими как отключение NVDA или "
"воспроизведение звуков ошибок."

#. Translators: the label for a check box
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:126
msgid ""
"Use a virtual list when listing up objects (does not work in Java "
"applications)"
msgstr ""
"Использовать виртуальный список при составлении списка объектов (не работает "
"в Java-приложениях)."

#. Translators: a label for a group
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:132
msgid "Settings for the virtual search list"
msgstr "Настройки для виртуального списка поиска"

#. Translators: The label for a check box
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:140
msgid "&Report object context while navigating"
msgstr "Соо&бщать о контексте объекта во время навигации"

#. Translators: The label for a check box
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:144
msgid "When holding down left alt, use first letter navigation"
msgstr ""
"Использовать навигацию по первой букве при удержании в нажатом состоянии "
"левой клавиши Alt"

#. Translators: a label for a group
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:148
msgid "Settings for the physical search list"
msgstr "Настройки для физического списка поиска"

#. Translators: The label for a check box
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:156
msgid ""
"Use UI automation when listing objects (same as in the virtual search list)"
msgstr ""
"Использовать UI automation при перечислении объектов (так же, как в "
"виртуальном списке поиска)"

#. Translators: The label for a check box
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:160
msgid "Use Regular expressions when searching"
msgstr "Использовать регулярные выражения при поиске"

#. Translators: The label for a check box
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:164
msgid ""
"When in navigation mode or in the search list, automatically update the "
"braille display when the content of the shown object changes. Disable if you "
"encounter problems using the add-on, such as lag"
msgstr ""
"В режиме навигации или в списке поиска автоматически обновлять брайлевский "
"дисплей при изменении содержимого отображаемого объекта. Отключите, если при "
"использовании дополнения возникнут проблемы, такие как задержка."

#. Translators: The label for a check box
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:168
msgid "Use sounds to indicate if navigation mode has been toggled"
msgstr ""
"Использовать звуковые сигналы, чтобы указать, был ли переключён режим "
"навигации"

#. Translators: The message reported when opening the item list
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:475
msgid "Loading items, please wait..."
msgstr "Загрузка элементов, пожалуйста, подождите..."

#. Translators: the message reported when NVDA fails to create the search list
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:484
msgid "No items found"
msgstr "Элементов не найдено"

#. Translators: the message reported when doing an action
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:736
msgid "uncheck"
msgstr "неотмечено"

#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:738
msgid "check"
msgstr "отмечено"

#. Translators: the message reported when doing an action
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:780
msgid "collapse"
msgstr "свёрнуто"

#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:782
msgid "expand"
msgstr "развёрнуто"

#. Translators: the message reported when doing an action
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:803
msgid "select"
msgstr "выделено"

#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:805
msgid "remove selection"
msgstr "удалить выделение"

#. Translators: the message reported when setting focus to a control
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:819
msgid "set focus"
msgstr "установить фокус"

#. Translators: the message reported when doing an action
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:833
msgid "Increase value"
msgstr "Увеличить значение"

#. Translators: the message reported when doing an action
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:847
msgid "Decrease value"
msgstr "Уменьшить значение"

#. Translators: The message reported when doing an action
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:863
msgid "Click"
msgstr "Клик"

#. Translators: The help text for the search list, to add compatibillity with the Control Usage Assistant addon.
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:982
msgid ""
"Use the arrow keys to move through this list. Start typing to filter the "
"list. Press enter to move the active cursor (e.g the focus, the browse mode "
"cursor, or the navigator object when navigation mode is turned on) to the "
"object represented by the current list item. Press backspace or delete to "
"remove the search text"
msgstr ""
"Используйте клавиши со стрелками для перемещения по этому списку. Начните "
"вводить текст, чтобы отфильтровать список. Нажмите клавишу Enter, чтобы "
"переместить активный курсор (например, фокус, курсор в режиме обзора или "
"объектный навигатор, когда включён режим навигации) на объект, "
"представленный текущим элементом списка. Нажмите клавишу BackSpace или "
"Delete, чтобы удалить текст для поиска"

#. Translators: the message reported when no items is found
#. Translators: The message reported when no items was found
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1073
#: addon\globalPlugins\enhancedObjectNavigation\objectList.py:189
msgid "No items"
msgstr "Нет элементов"

#. Translators: The action name for a object in the search list
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1093
msgid "move"
msgstr "переместить"

#. Translators: The message reported when resetting the search string
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1180
msgid "Search reset"
msgstr "Сброс поиска"

#. Translators: The message reported when the navigator object can not take focus
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1238
msgid "Unable to move focus"
msgstr "Не удаётся переместить фокус"

#. Translators: the message reported when the user entered a key that do not correspond to one of the quick nav keys
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1432
msgid "invalid key"
msgstr "Некорректная клавиша"

#. Translators: the message reported when no actions are available
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1441
msgid "No actions available"
msgstr "Нет доступных действий"

#. Translators: A rotor option:
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1455
msgid "Actions"
msgstr "Действия"

#. Translators: A rotor option:
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1457
msgid "control"
msgstr "элемент управления"

#. Translators: A rotor option
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1473
msgid "menu, menu bar or menu item"
msgstr "меню, строка меню или элемент меню"

#. Translators: A rotor option
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1475
msgid "tree or tree item"
msgstr "дерево или элемент дерева"

#. Translators: A rotor option
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1477
msgid "tab or tab item"
msgstr "панель вкладок или вкладка"

#. Translators: A rotor option
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1479
msgid "form field"
msgstr "поле формы"

#. Translators: A rotor option
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1481
msgid "focusable object"
msgstr "фокусируемый объект"

#. Translators: A rotor option
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1484
msgid "same item"
msgstr "такой же элемент"

#. Translators: A rotor option:
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1486
msgid "focusable form field"
msgstr "фокусируемое поле формы"

#. Translators: A string that will be reported after a role in some input help messages, such as in 'moves to the next button in the same application'
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1693
msgid "in the same application"
msgstr "в том же приложении"

#. Translators: The message reported before a role name in input help, such as 'Moves the navigator object to the next' in 'Moves the navigator object to the next button in the same application'
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1702
msgid "Moves the navigator object to the next"
msgstr "Перемещает объектный навигатор к следующему элементу типа"

#. Translators: The message reported before a role name in input help, such as 'Moves the navigator object to the previous' in 'Moves the navigator object to the previous button in the same application'
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1710
msgid "Moves the navigator object to the previous"
msgstr "Перемещает объектный навигатор к предыдущему элементу типа"

#. Translators: The message reported before a role name in input help, such as 'lists every button' in the sentence 'Lists every button in the window'
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1718
msgid "Lists every"
msgstr "Выводит все элементы типа"

#. Translators: the message reported after a role in input help, such as in the sentence 'Lists every button in the window'. Ignore this if not neaded for your language
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1721
msgid ""
"in the window or control where the navigator object is located, or  every "
"object on the screen, depending on what you have selected in settings"
msgstr ""
"в окне или элементе управления, где расположен объектный навигатор, или в "
"каждом объекте на экране, в зависимости от того, что вы выбрали в настройках"

#. Translators: The start of a script description
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1734
msgid "Emulates pressing"
msgstr "Имитирует нажатие"

#. Translators: The end of a script description
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1736
msgid "on the system keyboard"
msgstr "на системной клавиатуре"

#. Translators: the input help message for the UIANavigation script
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1799
msgid ""
"Turns on UIA navigation. This allows you to navigate through all "
"UIAutomation elements with the object navigation commands. This is most "
"useful for testing purposes."
msgstr ""
"Включает навигацию по UIA. Это позволяет вам перемещаться по всем элементам "
"UIAutomation с помощью команд объектной навигации. Это наиболее полезно для "
"целей тестирования."

#. Translators: the message reported when the user can not turn on UIA navigation
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1811
msgid "You can not turn on UIA navigation here"
msgstr "Вы не можете включить навигацию по UIA здесь"

#. Translators: the message indicating that UIA navigation mode has been turned on.
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1816
msgid "UIA navigation on"
msgstr "Навигация по UIA включена"

#. Translators: the input help message for the nextObject script
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1820
msgid "Moves to the next object within the same application"
msgstr "Переходит к следующему объекту в рамках того же приложения"

#. Translators: the description for the previousObject script
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1829
msgid "Moves to the previous object within the same application"
msgstr "Переходит к предыдущему объекту в рамках того же приложения"

#. Translators: the input help message for the nextRotorItem script
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1838
msgid "Moves to the next object depending on the rotor setting"
msgstr "Переходит к следующему объекту в зависимости от настройки ротора"

#. Translators: The message reported when a rotor item isn't availlable in the current situation
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1859
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1886
msgid "Not available here"
msgstr "Недоступно здесь"

#. Translators: the input help message for the previousRotorItem script
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1865
msgid "Moves to the previous object depending on the rotor setting"
msgstr "Перемещается к предыдущему объекту в зависимости от настройки ротора"

#. Translators: the input help message for the nextRotor script
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1891
msgid "selects the next rotor setting"
msgstr "выбирает следующую настройку ротора"

#. Translators: the input help message for the previousRotor script
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1901
msgid "selects the previous rotor setting"
msgstr "выбирает предыдущую настройку ротора"

#. Translators: the input help message for the navigationMode script
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1911
msgid "Turns on or off navigation mode."
msgstr "Включает или выключает режим навигации."

#. Translators: The message reported when the user is in browse mode and tries to turn on navigation mode
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1918
msgid ""
"Please disable browse mode with NVDA + space before using navigation mode"
msgstr ""
"Пожалуйста, отключите режим обзора при помощьи NVDA + Пробел перед "
"использованием режима навигации"

#. Translators: the input help message for the search script
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1932
msgid ""
"Lists every object in the current window, document or on the screen, "
"depending on what you have selected in the settings."
msgstr ""
"Выводит список всех объектов в текущем окне, документе или на экране, в "
"зависимости от того, что вы выбрали в настройках."

#. Translators: The description for a script
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:1979
msgid ""
"Selects, unselects, or decreases the value of the current navigator object "
"depending on what the object supports"
msgstr ""
"Выделяет, отменяет выделение или уменьшает значение текущего объекта "
"навигатора в зависимости от того, что поддерживает этот объект"

#. Translators: the description for a script
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:2018
msgid "Turns off or on advanced navigation"
msgstr "Выключает или включает расширенную навигацию"

#. Translators: The message reported when toggeling advanced navigation
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:2028
msgid "Advanced navigation on"
msgstr "Расширенная навигация включена"

#. Translators: The message reported when toggeling advanced navigation
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:2031
msgid "Advanced navigation off"
msgstr "Расширенная навигация выключена"

#. Translators: the description for a script
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:2035
msgid ""
"Tryes to set focus to the current navigator object, and then passes the "
"gesture through to the application"
msgstr ""
"Пытается установить фокус на текущий объект навигатора, а затем передаёт "
"жест в приложение"

#. Translators: the description for a script
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:2046
msgid "moves the navigator object to the first object in the current container"
msgstr "перемещает объектный навигатор к первому объекту в текущем контейнере"

#. Translators: The description for a script
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:2058
msgid "Moves the navigator object to the last object in the current container"
msgstr ""
"Перемещает объектный навигатор к последнему объекту в текущем контейнере"

#. Translators: the description for a script
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:2071
msgid ""
"Allows you to press a key, to list up all objects coresponding to that key, "
"e.g b for buttons, or f for form fields"
msgstr ""
"Позволяет нажать клавишу, чтобы отобразить список всех объектов, "
"соответствующих этой клавише, например, B для кнопок или F для полей форм"

#. Translators: The message reported when entering layered search
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:2075
msgid "Press the key that corresponds to the item type you want to list up"
msgstr ""
"Нажмите клавишу, соответствующую типу элемента, который вы хотите отобразить "
"в списке"

#. Translators: The description for a script
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:2080
msgid "Moves the navigator object to the end of the current application"
msgstr "Перемещает объектный навигатор в конец текущего приложения"

#. Translators: The description for a script
#: addon\globalPlugins\enhancedObjectNavigation\__init__.py:2108
msgid "Moves the navigator object to the beginning of the current application"
msgstr "Перемещает объектный навигатор в начало текущего приложения"

#. Translators: The title of the search dialog
#: addon\globalPlugins\enhancedObjectNavigation\objectList.py:42
msgid "Search"
msgstr "Поиск"

#. Translators: The label for an edit control in the object list dialog
#: addon\globalPlugins\enhancedObjectNavigation\objectList.py:110
msgid "Filter by &control type"
msgstr "Фильтровать по &типу элемента управления"

#. Translators: The label for an edit control in the object list dialog
#: addon\globalPlugins\enhancedObjectNavigation\objectList.py:115
msgid "Filter by n&ame"
msgstr "Фильтровать по &названию"

#. Translators: the label for a list box in the object list dialog
#: addon\globalPlugins\enhancedObjectNavigation\objectList.py:119
msgid "&Objects"
msgstr "&Объекты"

#. Translators: The label for a button in the object list dialog
#: addon\globalPlugins\enhancedObjectNavigation\objectList.py:123
msgid "Move &navigator object"
msgstr "&Переместить объектный навигатор"

#. Add-on description
#. Translators: Long description to be shown for this add-on on add-on information from add-ons manager
#: buildVars.py:26
msgid ""
"Allows you to use quick navigation everyware, and to search for objects  by "
"name"
msgstr ""
"Позволяет использовать быструю навигацию в любом программном обеспечении и "
"осуществлять поиск объектов по названию"
